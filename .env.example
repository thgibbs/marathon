# Marathon — example environment variables.
# Copy to `.env` (gitignored) for local dev. Production uses the secret store, not this file.
# Setup walkthrough: docs/quickstart.md (accounts/keys checklist: PREREQUISITES.md).

# --- Model providers (at least one; the agent's model policy names the provider) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# --- Slack surface (make slack-app) ---
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
# Socket Mode app-level token (xapp-), required by the live listener.
SLACK_APP_TOKEN=

# --- GitHub (brokered gh/git credential + document surface) ---
# GitHub App (preferred, §2b #15) or a fine-grained token. With App
# credentials set, Marathon mints installation access tokens (App JWT ->
# ~1h token, auto-refreshed) and every comment/PR authors as
# <app-slug>[bot]; GITHUB_TOKEN is the quickstart fallback (posts author as
# the token's user). Either way the credential is BROKERED: it is injected
# host-side into `github.exec`/`git.exec` child processes only — it never
# enters the sandbox, the model prompt, or the trace. The App needs the
# write permissions the PAT holds today (Contents + Pull requests + Issues).
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
# Identity linking (§7.20): the App's OAuth client credentials (user
# authorization, identity-only) power `/marathon link github` — a Slack user
# proves control of a GitHub login; Marathon stores the user-to-server token
# (encrypted under MARATHON_SECRET_KEY) as the per-user access checker.
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Public base URL of the github-app HTTP server (hosts /auth/github/*); the
# Slack app builds the `/marathon link github` URL from it.
MARATHON_LINK_BASE_URL=
# or, for early read-only work / quickstart:
GITHUB_TOKEN=
# Repo owner for the GitHub document app tenant (make github-app).
GITHUB_OWNER=
# Dev webhook proxy (no tunnel): a smee.io channel URL. When set, the live
# github-app SUBSCRIBES outbound to the channel and feeds deliveries through
# the same signature-verified receiver. Point the GitHub App's webhook URL at
# the same channel once. Leave unset in production (plain receiver).
MARATHON_WEBHOOK_PROXY=

# --- Deployment tenant (§2b #14) ---
# One name for this deployment. Both live apps (Slack + GitHub) bind their
# surface to this ONE tenant, so cross-surface work (doc PR drafted from a
# Slack ask, revised from a GitHub comment) shares artifacts, tasks, and
# memory. Leave unset only for isolated demo/test runs.
MARATHON_TENANT=

# --- Agents (Track 14) ---
# Directory of YAML agent definitions; the first file is the default agent.
# See agents/forge.yaml for the full config shape.
MARATHON_AGENTS_DIR=agents

# --- BUILD sandbox (code tasks) ---
# Toolchain image for BUILD containers (build with `make sandbox-image`).
MARATHON_SANDBOX_IMAGE=marathon-sandbox:kernel
# Default network for BUILD containers: internet-enabled ("bridge", the
# default) or strict ("none"). Per-agent override: `sandbox.network` in the
# agent YAML. The boundary is credential-freedom, not the network.
MARATHON_SANDBOX_NETWORK=

# --- Marathon secret store ---
# Master key used to encrypt secrets at rest (generate a strong random value).
MARATHON_SECRET_KEY=

# --- Datastore (defaults match docker-compose) ---
DATABASE_URL=postgres://marathon:marathon@localhost:5432/marathon
