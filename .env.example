# Marathon — example environment variables.
# Copy to `.env` (gitignored) for local dev. Production uses the secret store, not this file.
# Setup walkthrough: docs/quickstart.md (accounts/keys checklist: PREREQUISITES.md).

# --- Model providers (at least one; the agent's model policy names the provider) ---
# ANTHROPIC_API_KEY also powers the Claude Code harness. On the default bridge
# posture this key is injected into the sandbox directly (model-proxy decision,
# claude-code-impl.md §4.1) — dedicate it to Marathon, budget-cap it at the
# provider, and rotate it; treat it as a spend credential, not a data one.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
# Claude Code SUBSCRIPTION auth (optional, §4.1): a headless OAuth token from
# `claude setup-token` runs the harness on a Claude Pro/Max subscription instead
# of per-token API billing. When set it takes precedence over ANTHROPIC_API_KEY,
# and no API key enters the sandbox. NOTE: it's a higher-value personal
# credential and is still readable by code in the container on bridge — keep it
# short-lived / dev-scoped. It is DEV-ONLY and fails closed: the live apps refuse
# to boot with a token set unless you also acknowledge the risk below.
CLAUDE_CODE_OAUTH_TOKEN=
# Acknowledge the dev-only subscription-auth risk (§4.1) — required to enable
# CLAUDE_CODE_OAUTH_TOKEN. Set to 1 for local dev; leave unset in any shared/prod
# deployment (use ANTHROPIC_API_KEY or the model proxy there).
MARATHON_CLAUDE_SUBSCRIPTION_DEV=

# --- Slack surface (make slack-app) ---
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
# Socket Mode app-level token (xapp-), required by the live listener.
SLACK_APP_TOKEN=

# --- GitHub (brokered gh/git credential + document surface) ---
# GitHub App (preferred, §2b #15) or a fine-grained token. With App
# credentials set, Marathon mints installation access tokens (App JWT ->
# ~1h token, auto-refreshed) and every comment/PR authors as
# <app-slug>[bot]; GITHUB_TOKEN is the quickstart fallback (posts author as
# the token's user). Either way the credential is BROKERED: it is injected
# host-side into `github.exec`/`git.exec` child processes only — it never
# enters the sandbox, the model prompt, or the trace. The App needs the
# write permissions the PAT holds today (Contents + Pull requests + Issues).
GITHUB_APP_ID=
# The App private key, TWO ways (path wins when both are set):
#  - GITHUB_APP_PRIVATE_KEY_PATH: path to the downloaded .pem (easiest locally —
#    no multi-line pasting). Generate it in the App settings (Private keys →
#    Generate a private key), which downloads a *.private-key.pem file.
#  - GITHUB_APP_PRIVATE_KEY: the PEM inline (for secret managers). A multi-line
#    quoted value works; literal `\n` escapes are also accepted.
# NOTE: use the .pem file CONTENTS, not the "SHA256:…" fingerprint shown in the
# UI — that's just a label and will fail at boot with a clear message.
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
# Identity linking (§7.20): the App's OAuth client credentials (user
# authorization, identity-only) power `/marathon link github` — a Slack user
# proves control of a GitHub login; Marathon stores the user-to-server token
# (encrypted under MARATHON_SECRET_KEY) as the per-user access checker.
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Public base URL of the github-app HTTP server (hosts /auth/github/*); the
# Slack app builds the `/marathon link github` URL from it.
MARATHON_LINK_BASE_URL=
# or, for early read-only work / quickstart:
GITHUB_TOKEN=
# Repo owner for the GitHub document app tenant (make github-app).
GITHUB_OWNER=
# Dev webhook proxy (no tunnel): a smee.io channel URL. When set, the live
# github-app SUBSCRIBES outbound to the channel and feeds deliveries through
# the same signature-verified receiver. Point the GitHub App's webhook URL at
# the same channel once. Leave unset in production (plain receiver).
MARATHON_WEBHOOK_PROXY=

# --- Deployment tenant (§2b #14) ---
# One name for this deployment. Both live apps (Slack + GitHub) bind their
# surface to this ONE tenant, so cross-surface work (doc PR drafted from a
# Slack ask, revised from a GitHub comment) shares artifacts, tasks, and
# memory. Leave unset only for isolated demo/test runs.
MARATHON_TENANT=

# --- Agents (Track 14) ---
# Directory of YAML agent definitions; the first file is the default agent.
# See agents/forge.yaml for the full config shape.
MARATHON_AGENTS_DIR=agents

# --- BUILD sandbox (code tasks) ---
# Toolchain image for BUILD containers (build with `make sandbox-image`).
MARATHON_SANDBOX_IMAGE=marathon-sandbox:kernel
# Default network for BUILD containers: internet-enabled ("bridge", the
# default) or strict ("none"). Per-agent override: `sandbox.network` in the
# agent YAML. The boundary is business-credential-freedom, not the network.
MARATHON_SANDBOX_NETWORK=
# Claude Code broker transport (claude-code-impl.md §3.1). On macOS Docker
# Desktop a bind-mounted unix socket is not connectable from inside the
# container (ENOTSUP), so the governed-tool broker (document_revise, github.exec,
# …) never comes online. Set this to host.docker.internal to reach the broker
# over TCP instead. Leave unset on Linux (the unix socket works and is more
# isolated).
MARATHON_BROKER_HOST=
# Claude Code model proxy (OPTIONAL on bridge; claude-code-impl.md §4.1). Unset
# → the harness injects the Anthropic key directly (the default). Set it to a
# container-reachable AnthropicKeyProxy URL (NOT loopback) to keep the key out
# of the container. Required only for the locked-down `network: none` posture.
MARATHON_MODEL_PROXY_URL=

# --- Trust profile (design §30) ---
# The single named preset that sets the default of every posture knob:
# solo | team | org | hosted. Defaults to `solo` (the out-of-the-box kernel
# posture) — leave unset for solo-dev use; the quickstart needs nothing here.
# Each live app prints its effective posture at boot (§30.5). Flip to `team`
# when a second human joins the workspace (see design §30.6 for the checklist).
MARATHON_TRUST_PROFILE=
# Internal egress mode override (§7.8): open | on-behalf-of | audience. Normally
# the profile default; set only to deviate. Loosening it below the profile
# default requires the acknowledgment below (fail-closed otherwise).
MARATHON_INTERNAL_EGRESS_MODE=
# Loosening acknowledgments (§30.5) — set to 1 to consciously run a knob looser
# than the profile default. Each emits a loud startup warning + audit event.
MARATHON_ALLOW_LOOSER_EGRESS=
MARATHON_ALLOW_TRUSTED_DEPLOYMENT=

# --- Marathon secret store ---
# Master key used to encrypt secrets at rest (generate a strong random value).
MARATHON_SECRET_KEY=

# --- Datastore (defaults match docker-compose) ---
DATABASE_URL=postgres://marathon:marathon@localhost:5432/marathon
