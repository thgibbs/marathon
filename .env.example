# Marathon — example environment variables.
# Copy to `.env` (gitignored) for local dev. Production uses the secret store, not this file.
# See PREREQUISITES.md.

# --- Model providers (at least ANTHROPIC_API_KEY to start) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# --- Slack surface (M4+) ---
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# --- GitHub (tools + document surface, M3+) ---
# GitHub App (preferred) or a fine-grained token.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
# or, for early read-only work:
GITHUB_TOKEN=

# --- Marathon secret store (M0) ---
# Master key used to encrypt secrets at rest (generate a strong random value).
MARATHON_SECRET_KEY=

# --- Datastore (defaults match docker-compose) ---
DATABASE_URL=postgres://marathon:marathon@localhost:5432/marathon
